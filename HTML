<!DOCTYPE html>
<html lang="ja">
<head>
  <base target="_top">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5F4F0;
      --surface: #FFFFFF;
      --surface2: #EFEFEA;
      --border: rgba(0,0,0,0.08);
      --border-strong: rgba(0,0,0,0.14);
      --text-primary: #1A1916;
      --text-secondary: #6B6A65;
      --text-muted: #A09F9A;
      --income: #1D6E47;
      --income-bg: #E8F5EE;
      --work: #8A4F10;
      --work-bg: #FBF0E3;
      --private: #1A4A7A;
      --private-bg: #E3EEF9;
      --danger: #B53A2A;
      --accent: #1A1916;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 18px;
      --radius-xl: 24px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      min-height: 100vh;
      -webkit-tap-highlight-color: transparent;
      -webkit-font-smoothing: antialiased;
    }

    .app { max-width: 480px; margin: 0 auto; padding: 0 0 100px; }

    /* ── Header ── */
    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 20px 12px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .header-title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .header-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .gear-btn {
      width: 28px; height: 28px;
      background: none;
      border: none;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-muted);
      font-size: 16px;
      border-radius: 50%;
      transition: background 0.15s, color 0.15s;
      padding: 0;
    }
    .gear-btn:active, .gear-btn:hover { background: var(--surface2); color: var(--text-primary); }
    .month-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .month-nav-btn {
      width: 32px; height: 32px;
      background: var(--surface2);
      border: none; border-radius: 50%;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-secondary);
      font-size: 14px;
      transition: background 0.15s;
    }
    .month-nav-btn:active { background: var(--border-strong); }
    .month-label {
      font-family: 'DM Mono', monospace;
      font-size: 22px;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--text-primary);
    }
    .month-label span { color: var(--text-muted); font-size: 14px; }

    /* ── Summary Cards ── */
    .summary-section { padding: 16px 16px 0; }
    .balance-card {
      background: var(--accent);
      color: #fff;
      border-radius: var(--radius-xl);
      padding: 20px 22px;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .balance-card.negative { background: var(--danger); }
    .balance-label { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.6; margin-bottom: 4px; }
    .balance-amount { font-family: 'DM Mono', monospace; font-size: 28px; font-weight: 500; letter-spacing: -0.02em; }
    .balance-sub { font-size: 10px; opacity: 0.5; margin-top: 2px; }
    .balance-pill {
      background: rgba(255,255,255,0.15);
      border-radius: 100px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 700;
    }
    .sub-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .sub-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 12px 10px;
      text-align: center;
    }
    .sub-card-label { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 4px; }
    .sub-card-amount { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; }
    .sub-card.income .sub-card-label { color: var(--income); }
    .sub-card.income .sub-card-amount { color: var(--income); }
    .sub-card.work .sub-card-label { color: var(--work); }
    .sub-card.work .sub-card-amount { color: var(--work); }
    .sub-card.private .sub-card-label { color: var(--private); }
    .sub-card.private .sub-card-amount { color: var(--private); }

    /* ── Tab Nav ── */
    .tab-nav {
      display: flex;
      padding: 0 16px;
      gap: 6px;
      margin-bottom: 0;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
    }
    .tab-btn {
      padding: 10px 14px;
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: none; border: none;
      cursor: pointer;
      color: var(--text-muted);
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.15s;
    }
    .tab-btn.active { color: var(--text-primary); border-bottom-color: var(--text-primary); }

    /* ── Entry Form ── */
    .form-section { padding: 16px; }
    .form-card {
      background: var(--surface);
      border-radius: var(--radius-xl);
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .type-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      border-bottom: 1px solid var(--border);
    }
    .type-tab {
      padding: 12px 8px;
      text-align: center;
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border: none; background: none; cursor: pointer;
      color: var(--text-muted);
      border-bottom: 2px solid transparent;
      transition: all 0.15s;
    }
    .type-tab.active-private { color: var(--private); border-bottom-color: var(--private); background: var(--private-bg); }
    .type-tab.active-work    { color: var(--work);    border-bottom-color: var(--work);    background: var(--work-bg); }
    .type-tab.active-income  { color: var(--income);  border-bottom-color: var(--income);  background: var(--income-bg); }

    .form-body { padding: 16px; }
    .form-row { margin-bottom: 10px; }
    .form-row label {
      display: block;
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 5px;
    }
    .form-input, .form-select {
      width: 100%; padding: 10px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px; font-weight: 500;
      color: var(--text-primary);
      outline: none;
      appearance: none;
      transition: border-color 0.15s;
    }
    .form-input:focus, .form-select:focus { border-color: var(--border-strong); background: var(--surface); }
    .form-select-wrap { position: relative; }
    .form-select-wrap::after {
      content: '▾';
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      color: var(--text-muted); font-size: 11px; pointer-events: none;
    }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

    /* ── Amount ── */
    .amount-area {
      background: var(--bg);
      border-radius: var(--radius-md);
      padding: 12px 16px;
      margin-bottom: 10px;
    }
    .amount-display {
      display: flex; align-items: baseline; gap: 6px;
      margin-bottom: 8px;
    }
    .amount-currency { font-size: 18px; color: var(--text-muted); font-weight: 500; }
    .amount-input {
      font-family: 'DM Mono', monospace;
      font-size: 36px; font-weight: 500;
      border: none; background: transparent;
      outline: none; width: 100%;
      color: var(--text-primary);
    }
    .calc-row { display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; }
    .calc-btn {
      padding: 8px 4px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 12px; font-weight: 700;
      color: var(--text-secondary);
      cursor: pointer;
      transition: background 0.1s;
    }
    .calc-btn:active { background: var(--surface2); }
    .calc-btn.calc-eq { background: var(--text-primary); color: white; border-color: var(--text-primary); }

    .save-btn {
      width: 100%; padding: 14px;
      background: var(--text-primary);
      color: white;
      border: none; border-radius: var(--radius-md);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .save-btn:active { opacity: 0.8; }
    .save-btn.editing { background: #2855A0; }
    .cancel-btn {
      width: 100%; padding: 10px;
      background: none; border: 1px solid var(--border);
      border-radius: var(--radius-md);
      font-family: 'DM Sans', sans-serif;
      font-size: 12px; font-weight: 700;
      color: var(--text-secondary); cursor: pointer;
      margin-top: 6px;
    }

    /* ── History ── */
    .history-section { padding: 0 16px; }
    .date-group { margin-bottom: 6px; }
    .date-header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 8px 2px 6px;
    }
    .date-header-label { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; color: var(--text-secondary); }
    .date-header-total { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text-muted); }

    .tx-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      margin-bottom: 5px;
      display: flex; align-items: center;
      overflow: hidden;
      cursor: pointer;
      transition: background 0.1s;
    }
    .tx-item:active { background: var(--surface2); }
    .tx-stripe { width: 4px; align-self: stretch; flex-shrink: 0; }
    .tx-stripe.income  { background: var(--income); }
    .tx-stripe.work    { background: #D47B20; }
    .tx-stripe.private { background: #3476C7; }
    .tx-body { flex: 1; padding: 10px 12px; min-width: 0; }
    .tx-meta { font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 2px; }
    .tx-name { font-size: 14px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tx-right { display: flex; align-items: center; gap: 6px; padding-right: 6px; }
    .tx-amount { font-family: 'DM Mono', monospace; font-size: 15px; font-weight: 500; white-space: nowrap; }
    .tx-amount.income  { color: var(--income); }
    .tx-amount.expense { color: var(--text-primary); }
    .tx-delete {
      width: 30px; height: 30px;
      background: none; border: none;
      color: var(--text-muted);
      font-size: 18px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }
    .tx-delete:active { background: #FEE2E2; color: var(--danger); }

    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); }
    .empty-state p { font-size: 13px; margin-top: 8px; }

    /* ── Loading ── */
    .loading-overlay {
      position: fixed; inset: 0;
      background: rgba(245,244,240,0.85);
      backdrop-filter: blur(4px);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      z-index: 100; gap: 12px;
    }
    .spinner {
      width: 28px; height: 28px;
      border: 3px solid var(--border-strong);
      border-top-color: var(--text-primary);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    .loading-text { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-secondary); }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Settings Modal ── */
    .modal-backdrop {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.35);
      z-index: 50;
      display: flex; align-items: flex-end; justify-content: center;
    }
    .modal-sheet {
      background: var(--surface);
      border-radius: var(--radius-xl) var(--radius-xl) 0 0;
      width: 100%; max-width: 480px;
      max-height: 82vh;
      display: flex; flex-direction: column;
      overflow: hidden;
      animation: slideUp 0.22s ease;
    }
    @keyframes slideUp {
      from { transform: translateY(60px); opacity: 0; }
      to   { transform: translateY(0);    opacity: 1; }
    }
    .modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .modal-title {
      font-size: 13px; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text-primary);
    }
    .modal-close {
      width: 28px; height: 28px;
      background: var(--surface2); border: none; border-radius: 50%;
      font-size: 14px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-secondary);
    }
    .modal-close:active { background: var(--border-strong); }
    .modal-body { overflow-y: auto; padding: 16px 20px 32px; flex: 1; }

    .settings-type-tabs {
      display: flex; gap: 6px;
      margin-bottom: 16px;
    }
    .settings-type-tab {
      flex: 1; padding: 8px 4px;
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.07em; text-transform: uppercase;
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); cursor: pointer;
      color: var(--text-muted);
      transition: all 0.15s;
    }
    .settings-type-tab.active-private { background: var(--private-bg); color: var(--private); border-color: var(--private); }
    .settings-type-tab.active-work    { background: var(--work-bg);    color: var(--work);    border-color: var(--work); }
    .settings-type-tab.active-income  { background: var(--income-bg);  color: var(--income);  border-color: var(--income); }

    .settings-group { margin-bottom: 18px; }
    .settings-group-label {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .tag-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
    .tag-chip {
      display: inline-flex; align-items: center; gap: 4px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 4px 10px 4px 12px;
      font-size: 12px; font-weight: 500;
      color: var(--text-primary);
    }
    .tag-chip-del {
      background: none; border: none;
      color: var(--text-muted);
      font-size: 13px; cursor: pointer;
      line-height: 1; padding: 0;
      display: flex; align-items: center;
    }
    .tag-chip-del:active { color: var(--danger); }
    .tag-add-row {
      display: flex; gap: 6px; align-items: stretch;
    }
    .tag-add-input {
      flex: 1; padding: 8px 10px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 500;
      color: var(--text-primary);
      outline: none;
    }
    .tag-add-input:focus { border-color: var(--border-strong); background: var(--surface); }
    .tag-add-submit {
      padding: 8px 14px;
      background: var(--text-primary);
      color: white;
      border: none; border-radius: var(--radius-sm);
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
    }
    .tag-add-submit:active { opacity: 0.8; }
    .tag-add-submit:disabled { opacity: 0.4; cursor: default; }
    .settings-divider {
      border: none; border-top: 1px solid var(--border);
      margin: 14px 0;
    }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useState, useEffect, useRef } = React;
    const fmt   = n => Number(n).toLocaleString('ja-JP');
    const TODAY = new Date().toISOString().split('T')[0];

    const TYPE_CONFIG = {
      '支出（プライベート）': { label: 'Private', tabClass: 'active-private', stripe: 'private', catKey: 'HOME_cat', methodKey: 'HOME_method' },
      '支出（For Two）':     { label: 'For Two',  tabClass: 'active-work',    stripe: 'work',    catKey: 'WORK_cat',   methodKey: 'WORK_method' },
      '収入':                 { label: 'Income',   tabClass: 'active-income',  stripe: 'income',  catKey: 'INCOME_cat', methodKey: 'INCOME_method' }
    };
    const TYPES = Object.keys(TYPE_CONFIG);

    function getStripe(type) {
      if (type.includes('収入') || type.toUpperCase().includes('INCOME')) return 'income';
      if (type.includes('For Two')) return 'work';
      return 'private';
    }

    /* ────────────────────────────────────────────
       ★ TagGroup をトップレベルに定義（これが修正の核心）
       SettingsModal の内側に書くと再レンダリングのたびに
       コンポーネントが再生成されてフォーカスが失われ
       1文字しか入力できなくなる
    ──────────────────────────────────────────── */
    function TagGroup({ label, colKey, tags, inputVal, setInput, onAdd, onDelete, busy }) {
      return (
        <div className="settings-group">
          <div className="settings-group-label">{label}</div>
          <div className="tag-list">
            {tags.length === 0 && (
              <span style={{fontSize:12, color:'var(--text-muted)'}}>まだタグがありません</span>
            )}
            {tags.map(tag => (
              <span key={tag} className="tag-chip">
                {tag}
                <button
                  className="tag-chip-del"
                  onClick={() => onDelete(colKey, tag)}
                  disabled={busy}
                  title="削除"
                >×</button>
              </span>
            ))}
          </div>
          <div className="tag-add-row">
            <input
              className="tag-add-input"
              type="text"
              placeholder="新しいタグを入力"
              value={inputVal}
              onChange={e => setInput(e.target.value)}
              onKeyDown={e => { if (e.key === 'Enter') onAdd(colKey, inputVal, setInput); }}
              disabled={busy}
            />
            <button
              className="tag-add-submit"
              onClick={() => onAdd(colKey, inputVal, setInput)}
              disabled={busy || !inputVal.trim()}
            >追加</button>
          </div>
        </div>
      );
    }

    /* ────────────────────────────────────────────
       設定モーダル
    ──────────────────────────────────────────── */
    function SettingsModal({ settings, onClose, onSettingsUpdated }) {
      const [activeType,  setActiveType]  = useState(TYPES[0]);
      const [catInput,    setCatInput]    = useState('');
      const [methodInput, setMethodInput] = useState('');
      const [busy,        setBusy]        = useState(false);

      const cfg = TYPE_CONFIG[activeType];

      const handleAddTag = (colKey, value, clearFn) => {
        const trimmed = value.trim();
        if (!trimmed || busy) return;
        setBusy(true);
        google.script.run
          .withSuccessHandler(updated => {
            onSettingsUpdated(updated);
            clearFn('');
            setBusy(false);
          })
          .withFailureHandler(err => {
            alert('保存失敗: ' + (err.message || err));
            setBusy(false);
          })
          .saveTag(colKey, trimmed);
      };

      const handleDeleteTag = (colKey, tagValue) => {
        if (!confirm(`「${tagValue}」を削除しますか？`)) return;
        setBusy(true);
        google.script.run
          .withSuccessHandler(updated => {
            onSettingsUpdated(updated);
            setBusy(false);
          })
          .withFailureHandler(err => {
            alert('削除失敗: ' + (err.message || err));
            setBusy(false);
          })
          .deleteTag(colKey, tagValue);
      };

      return (
        <div className="modal-backdrop" onClick={e => { if (e.target === e.currentTarget) onClose(); }}>
          <div className="modal-sheet">
            <div className="modal-header">
              <span className="modal-title">⚙ タグ設定</span>
              <button className="modal-close" onClick={onClose}>✕</button>
            </div>
            <div className="modal-body">
              <div className="settings-type-tabs">
                {TYPES.map(t => (
                  <button
                    key={t}
                    className={`settings-type-tab ${activeType === t ? TYPE_CONFIG[t].tabClass : ''}`}
                    onClick={() => { setActiveType(t); setCatInput(''); setMethodInput(''); }}
                  >
                    {TYPE_CONFIG[t].label}
                  </button>
                ))}
              </div>

              <TagGroup
                label="カテゴリ"
                colKey={cfg.catKey}
                tags={settings[cfg.catKey] || []}
                inputVal={catInput}
                setInput={setCatInput}
                onAdd={handleAddTag}
                onDelete={handleDeleteTag}
                busy={busy}
              />
              <hr className="settings-divider" />
              <TagGroup
                label="支払方法"
                colKey={cfg.methodKey}
                tags={settings[cfg.methodKey] || []}
                inputVal={methodInput}
                setInput={setMethodInput}
                onAdd={handleAddTag}
                onDelete={handleDeleteTag}
                busy={busy}
              />
            </div>
          </div>
        </div>
      );
    }

    /* ────────────────────────────────────────────
       メインアプリ
    ──────────────────────────────────────────── */
    function App() {
      const [loading,      setLoading]      = useState(true);
      const [data,         setData]         = useState({ monthly: { income:0, expense:0, balance:0, workExpense:0, privateExpense:0 }, history:[], settings:{}, currentMonth:'' });
      const [month,        setMonth]        = useState(new Date().toISOString().slice(0, 7));
      const [activeTab,    setActiveTab]    = useState('history');
      const [showSettings, setShowSettings] = useState(false);

      const emptyForm = (settings, type) => {
        const cfg = TYPE_CONFIG[type] || TYPE_CONFIG[TYPES[0]];
        const s   = settings || {};
        return {
          date:       TODAY,
          type,
          category:   (s[cfg.catKey]    || [''])[0],
          method:     (s[cfg.methodKey] || [''])[0],
          item:       '',
          amount:     '',
          editingRow: null
        };
      };
      const [form, setForm] = useState(emptyForm({}, TYPES[0]));

      useEffect(() => { load(month); }, [month]);

      const load = (m) => {
        setLoading(true);
        google.script.run.withSuccessHandler(res => {
          setData(res);
          setLoading(false);
        }).getReportData(m);
      };

      const changeType = (type) => setForm(f => ({ ...emptyForm(data.settings, type), date: f.date }));

      const changeMonth = (delta) => {
        const d = new Date(month + '-01');
        d.setMonth(d.getMonth() + delta);
        setMonth(d.toISOString().slice(0, 7));
      };

      const runCalc = () => {
        try {
          const clean = String(form.amount).replace(/[^0-9+\-*/.]/g, '');
          if (!clean) return;
          setForm(f => ({ ...f, amount: Math.floor(eval(clean)).toString() }));
        } catch { alert('計算エラー'); }
      };

      const handleSubmit = () => {
        if (!form.item || !form.amount) return;
        setLoading(true);
        if (form.editingRow) {
          google.script.run
            .withSuccessHandler(() => { load(month); setActiveTab('history'); })
            .updateRow(form.editingRow, form);
        } else {
          google.script.run
            .withSuccessHandler(() => { load(month); setActiveTab('history'); })
            .processForm(form);
        }
      };

      const startEdit = (item) => {
        setForm({ date: item.fullDate, type: item.type, category: item.cat, method: item.method, item: item.item, amount: item.amount.toString(), editingRow: item.row });
        setActiveTab('entry');
      };

      const cancelEdit = () => {
        setForm(emptyForm(data.settings, form.type));
        setActiveTab('history');
      };

      const handleSettingsUpdated = (updatedSettings) => {
        setData(prev => ({ ...prev, settings: updatedSettings }));
        setForm(f => {
          const cfg     = TYPE_CONFIG[f.type];
          const cats    = updatedSettings[cfg.catKey]    || [];
          const methods = updatedSettings[cfg.methodKey] || [];
          return {
            ...f,
            category: cats.includes(f.category)   ? f.category : (cats[0]    || ''),
            method:   methods.includes(f.method)   ? f.method   : (methods[0] || ''),
          };
        });
      };

      const grouped = data.history.reduce((acc, item) => {
        if (!acc[item.fullDate]) acc[item.fullDate] = { date: item.date, items: [], spent: 0 };
        acc[item.fullDate].items.push(item);
        if (!item.type.includes('収入') && !item.type.toUpperCase().includes('INCOME')) {
          acc[item.fullDate].spent += item.amount;
        }
        return acc;
      }, {});
      const sortedDates = Object.keys(grouped).sort((a, b) => new Date(b) - new Date(a));

      const [yr, mo] = month.split('-');
      const bal = data.monthly.balance;

      return (
        <div className="app">

          {/* Header */}
          <div className="header">
            <div className="header-title-row">
              <div className="header-title">For Two — 家計簿</div>
              <button className="gear-btn" onClick={() => setShowSettings(true)} title="タグ設定">⚙</button>
            </div>
            <div className="month-nav">
              <button className="month-nav-btn" onClick={() => changeMonth(-1)}>◂</button>
              <div className="month-label">{yr} <span>/</span> {mo}</div>
              <button className="month-nav-btn" onClick={() => changeMonth(1)}>▸</button>
            </div>
          </div>

          {/* Summary */}
          <div className="summary-section">
            <div className={`balance-card ${bal < 0 ? 'negative' : ''}`}>
              <div>
                <div className="balance-label">Balance</div>
                <div className="balance-amount">¥{fmt(Math.abs(bal))}</div>
                <div className="balance-sub">{bal >= 0 ? '黒字' : '赤字'}</div>
              </div>
              <div className="balance-pill">{bal >= 0 ? '+' : '−'}{fmt(Math.abs(bal))}</div>
            </div>
            <div className="sub-cards">
              <div className="sub-card income">
                <div className="sub-card-label">収入</div>
                <div className="sub-card-amount">¥{fmt(data.monthly.income)}</div>
              </div>
              <div className="sub-card work">
                <div className="sub-card-label">For Two</div>
                <div className="sub-card-amount">¥{fmt(data.monthly.workExpense)}</div>
              </div>
              <div className="sub-card private">
                <div className="sub-card-label">Private</div>
                <div className="sub-card-amount">¥{fmt(data.monthly.privateExpense)}</div>
              </div>
            </div>
          </div>

          {/* Tab Navigation */}
          <div className="tab-nav">
            <button className={`tab-btn ${activeTab === 'history' ? 'active' : ''}`}
              onClick={() => { setActiveTab('history'); if (form.editingRow) cancelEdit(); }}>
              履歴
            </button>
            <button className={`tab-btn ${activeTab === 'entry' ? 'active' : ''}`}
              onClick={() => setActiveTab('entry')}>
              {form.editingRow ? '編集中' : '入力'}
            </button>
          </div>

          {/* Entry Form */}
          {activeTab === 'entry' && (
            <div className="form-section">
              <div className="form-card">
                <div className="type-tabs">
                  {TYPES.map(t => {
                    const cfg = TYPE_CONFIG[t];
                    return (
                      <button key={t} className={`type-tab ${form.type === t ? cfg.tabClass : ''}`} onClick={() => changeType(t)}>
                        {cfg.label}
                      </button>
                    );
                  })}
                </div>
                <div className="form-body">
                  <div className="form-row">
                    <label>日付</label>
                    <input type="date" className="form-input" value={form.date}
                      onChange={e => setForm(f => ({...f, date: e.target.value}))} />
                  </div>
                  <div className="form-row">
                    <label>内容</label>
                    <input type="text" className="form-input" placeholder="例：スーパー、ガソリン代…"
                      value={form.item} onChange={e => setForm(f => ({...f, item: e.target.value}))} />
                  </div>
                  <div className="form-grid form-row">
                    <div>
                      <label>カテゴリ</label>
                      <div className="form-select-wrap">
                        <select className="form-select" value={form.category}
                          onChange={e => setForm(f => ({...f, category: e.target.value}))}>
                          {(data.settings[TYPE_CONFIG[form.type]?.catKey] || []).map(c =>
                            <option key={c} value={c}>{c}</option>
                          )}
                        </select>
                      </div>
                    </div>
                    <div>
                      <label>支払方法</label>
                      <div className="form-select-wrap">
                        <select className="form-select" value={form.method}
                          onChange={e => setForm(f => ({...f, method: e.target.value}))}>
                          {(data.settings[TYPE_CONFIG[form.type]?.methodKey] || []).map(m =>
                            <option key={m} value={m}>{m}</option>
                          )}
                        </select>
                      </div>
                    </div>
                  </div>

                  <div className="amount-area">
                    <div className="amount-display">
                      <span className="amount-currency">¥</span>
                      <input type="text" className="amount-input" placeholder="0"
                        value={form.amount}
                        onChange={e => setForm(f => ({...f, amount: e.target.value}))} />
                    </div>
                    <div className="calc-row">
                      {['+', '−', '×', '÷', 'C', '='].map((op, i) => {
                        const ops = ['+', '-', '*', '/', '', '='];
                        return (
                          <button key={op} className={`calc-btn ${op === '=' ? 'calc-eq' : ''}`}
                            onClick={() => {
                              if (op === 'C') setForm(f => ({...f, amount: ''}));
                              else if (op === '=') runCalc();
                              else setForm(f => ({...f, amount: f.amount + ops[i]}));
                            }}>
                            {op}
                          </button>
                        );
                      })}
                    </div>
                  </div>

                  <button className={`save-btn ${form.editingRow ? 'editing' : ''}`} onClick={handleSubmit}>
                    {form.editingRow ? '更新する' : '保存する'}
                  </button>
                  {form.editingRow && (
                    <button className="cancel-btn" onClick={cancelEdit}>キャンセル</button>
                  )}
                </div>
              </div>
            </div>
          )}

          {/* History */}
          {activeTab === 'history' && (
            <div className="history-section" style={{paddingTop: 12}}>
              {sortedDates.length === 0 ? (
                <div className="empty-state">
                  <div style={{fontSize: 32}}>📋</div>
                  <p>この月のデータはありません</p>
                </div>
              ) : sortedDates.map(dateKey => {
                const group = grouped[dateKey];
                return (
                  <div key={dateKey} className="date-group">
                    <div className="date-header">
                      <span className="date-header-label">{group.date}</span>
                      {group.spent > 0 && <span className="date-header-total">支出 ¥{fmt(group.spent)}</span>}
                    </div>
                    {group.items.map((item, idx) => {
                      const stripe   = getStripe(item.type);
                      const isIncome = stripe === 'income';
                      return (
                        <div key={idx} className="tx-item" onClick={() => startEdit(item)}>
                          <div className={`tx-stripe ${stripe}`}></div>
                          <div className="tx-body">
                            <div className="tx-meta">{item.cat}{item.method ? ` · ${item.method}` : ''}</div>
                            <div className="tx-name">{item.item}</div>
                          </div>
                          <div className="tx-right">
                            <div className={`tx-amount ${isIncome ? 'income' : 'expense'}`}>
                              {isIncome ? '+' : ''}¥{fmt(item.amount)}
                            </div>
                            <button className="tx-delete" onClick={e => {
                              e.stopPropagation();
                              if (confirm('削除しますか？')) {
                                setLoading(true);
                                google.script.run
                                  .withSuccessHandler(() => load(month))
                                  .deleteRow(item.row);
                              }
                            }}>×</button>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                );
              })}
            </div>
          )}

          {/* Settings Modal */}
          {showSettings && (
            <SettingsModal
              settings={data.settings}
              onClose={() => setShowSettings(false)}
              onSettingsUpdated={handleSettingsUpdated}
            />
          )}

          {/* Loading Overlay */}
          {loading && (
            <div className="loading-overlay">
              <div className="spinner"></div>
              <div className="loading-text">Syncing...</div>
            </div>
          )}

        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById('root')).render(<App />);
  </script>
</body>
</html>
